# Tanvi App - Environment Variables
# Copy this to .env.local and update values

# App Configuration
NEXT_PUBLIC_APP_NAME=Tanvi
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: Firebase Configuration (for real-time features)
# NEXT_PUBLIC_FIREBASE_API_KEY=your_key_here
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_domain_here
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_here
